# ===== Django backend =====
# Copia este archivo como .env en tu entorno de despliegue.

SECRET_KEY=change-me-in-production
DEBUG=False

# Dominios permitidos por Django (separados por coma)
ALLOWED_HOSTS=api.tu-dominio.com

# CORS y CSRF para frontend
CORS_ALLOWED_ORIGINS=https://app.tu-dominio.com
CSRF_TRUSTED_ORIGINS=https://app.tu-dominio.com,https://api.tu-dominio.com

# Redirección opcional en /
FRONTEND_URL=https://app.tu-dominio.com

# Base de datos (recomendado Postgres en Dokploy)
# Ejemplo: postgres://user:password@host:5432/dbname
DATABASE_URL=
DB_SSL_REQUIRE=False

# Si usas proxy reverso
USE_X_FORWARDED_HOST=True
