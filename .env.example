# ===== Stack completo (docker-compose) =====
# Copia este archivo como .env en el VPS y completa los valores.
# Luego ejecuta:  docker compose up -d --build

# ── Django ───────────────────────────────────────────────────────────────
# Genera uno seguro con: python -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=change-me-in-production

DEBUG=False

# Con nginx delante, * es seguro. Si querés ser estricto: IP_VPS,app.enerit.net
ALLOWED_HOSTS=*

# Puerto donde nginx queda expuesto en el VPS (Dokploy apunta aquí)
PORT=80

# ── Base de datos SQLite (sin servicios adicionales) ─────────────────────
# Ruta interna usada por docker-compose para persistir la BD en un volumen.
DATABASE_URL=sqlite:////app/data/db.sqlite3

# ── CSRF (solo necesario para el panel /admin/ desde el dominio externo) ──
# Ejemplo: https://app.enerit.net
CSRF_TRUSTED_ORIGINS=

# CORS no es necesario porque nginx actúa como mismo origen.
# Dejá vacío salvo que necesites acceso desde otro origen.
CORS_ALLOWED_ORIGINS=

# Redirección en / → frontend (opcional)
FRONTEND_URL=

# El proxy de Dokploy/nginx pasa estas cabeceras; dejar en True.
USE_X_FORWARDED_HOST=True

# Activar solo si Dokploy termina SSL y pasa X-Forwarded-Proto: https
# (necesario para que Django genere URLs https en el admin, etc.)
TRUST_X_FORWARDED_PROTO=True
