# ===== React frontend =====
# En producción con docker-compose, nginx actúa de intermediario en el mismo
# dominio, por lo que la URL es relativa. No hace falta dominio externo.
VITE_API_BASE_URL=/api

# Solo si el frontend corre fuera de docker-compose (ej: desarrollo local):
# VITE_API_BASE_URL=http://localhost:8000/api
